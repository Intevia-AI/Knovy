# =============================================================================
# GEMINI AI WEBSOCKET CONNECTION
# =============================================================================
# WebSocket URL for connecting to the Gemini AI proxy server
# This should point to your running proxy server instance
# Default: ws://localhost:4567 (if running proxy locally)
# Production: Use your deployed proxy server URL
VITE_GEMINI_WS_URL=ws://localhost:4567

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Supabase project URL - obtain from your Supabase project dashboard
# Navigate to: Supabase Dashboard > Your Project > Settings > API
# Example: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key - obtain from your Supabase project dashboard
# Navigate to: Supabase Dashboard > Your Project > Settings > API > Project API keys
# Use the "anon" key (public key) - this is safe to expose in client-side code
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
