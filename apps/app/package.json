{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm --filter history-viewer dev\" \"electron-vite dev\"",
    "build:history": "pnpm --filter history-viewer build",
    "copy:history": "rm -rf src/renderer/public/history && cp -r ../history-viewer/out src/renderer/public/history",
    "build": "pnpm run build:history && pnpm run copy:history && electron-vite build && electron-rebuild && electron-builder",
    "postinstall": "electron-builder install-app-deps && electron-rebuild",
    "rebuild": "electron-rebuild"
  },
