{
  "name": "app",
  "version": "0.0.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n \"NEXT,ELECTRON\" -c \"yellow,blue\" --kill-others \"next dev\" \"electron .\"",
    "build": "next build && electron-builder",
    "prepare": "rimraf node_modules/electron/dist && node node_modules/electron/install.js"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.10",
    "@ai-sdk/react": "^1.2.8",
    "@google/generative-ai": "^0.24.0",
    "@hookform/resolvers": "^5.0.1",
    "@types/dotenv": "^8.2.3",
    "@types/wav": "^1.0.4",
    "@types/ws": "^8.18.1",
    "@workspace/ui": "workspace:*",
    "ai": "^4.3.5",
    "dotenv": "^16.5.0",
    "electron-is-dev": "^3.0.1",
    "electron-serve": "^2.1.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "motion": "^12.6.5",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "node-web-audio-api": "^1.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.55.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "standardized-audio-context": "^25.3.77",
    "tmp": "^0.2.3",
    "wav": "^1.0.2",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.17.30",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@types/tmp": "^0.2.6",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "concurrently": "^9.1.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.example.intevia-ai",
    "productName": "Intevia AI",
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
