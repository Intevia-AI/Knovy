# Proxy Server Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# GOOGLE GENERATIVE AI CONFIGURATION
# =============================================================================
# Google Generative AI API Key for Gemini integration
# Obtain from: Google AI Studio (https://aistudio.google.com/app/apikey)
# Or Google Cloud Console > APIs & Services > Credentials
# SECURITY: Keep this key secure and never commit it to version control
# Required for proxying requests to Google's Gemini AI services
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key-here

# =============================================================================
# PROXY SERVER CONFIGURATION
# =============================================================================
# Port number for the WebSocket proxy server
# Default: 4567 (commonly used for development)
# Production: Use port 80 (HTTP) or 443 (HTTPS) or configure reverse proxy
# Make sure this port is not in use by other services
# The proxy server will listen on this port for WebSocket connections
PROXY_PORT=4567

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================
# Server host binding (uncomment if needed)
# Default: localhost (127.0.0.1) for development
# Production: 0.0.0.0 to accept connections from any IP
# PROXY_HOST=localhost

# Enable debug logging (uncomment if needed)
# Values: true, false
# Enables detailed logging for debugging proxy connections
# DEBUG=false