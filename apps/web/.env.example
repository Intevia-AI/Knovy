# Web Application Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# GOOGLE GENERATIVE AI CONFIGURATION
# =============================================================================
# Google Generative AI API Key for Gemini integration
# Obtain from: Google AI Studio (https://aistudio.google.com/app/apikey)
# Or Google Cloud Console > APIs & Services > Credentials
# SECURITY: Keep this key secure and never commit it to version control
# Required for AI-powered features and real-time analysis
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key-here

# =============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# =============================================================================
# Gmail account for sending feedback and notification emails
# Use a dedicated service account or app-specific password
# SECURITY: Never use your personal Gmail password
GMAIL_USER=your-service-email@gmail.com

# Gmail App Password (not your regular Gmail password)
# Generate at: Google Account > Security > 2-Step Verification > App passwords
# SECURITY: This is sensitive - treat like a password
GMAIL_PASS=your-gmail-app-password-here

# =============================================================================
# PROXY SERVER CONFIGURATION
# =============================================================================
# WebSocket proxy server URL for Gemini AI connections
# This should point to your running proxy server instance
# Development: ws://localhost:4567 (if running proxy locally)
# Production: Your deployed Cloud Run URL (e.g., wss://your-service-url.a.run.app)
NEXT_PUBLIC_PROXY_SERVER_URL=ws://localhost:4567

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
# Node.js environment mode
# Values: development, production, test
# Affects logging, error handling, and performance optimizations
NODE_ENV=development