# Web Application Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# =============================================================================
# Gmail account for sending feedback and notification emails
# Use a dedicated service account or app-specific password
# SECURITY: Never use your personal Gmail password
GMAIL_USER=your-service-email@gmail.com

# Gmail App Password (not your regular Gmail password)
# Generate at: Google Account > Security > 2-Step Verification > App passwords
# SECURITY: This is sensitive - treat like a password
GMAIL_PASS=your-gmail-app-password-here

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
# Node.js environment mode
# Values: development, production, test
# Affects logging, error handling, and performance optimizations
NODE_ENV=development