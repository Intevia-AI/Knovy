# Environment
ENVIRONMENT=dev

# Set the production origin to null, which is what a production Electron app will send.
PRODUCTION_APP_ORIGIN=null

# Gemini API KEY
GOOGLE_GENERATIVE_AI_API_KEY=GOOGLE_GENERATIVE_AI_API_KEY

# Supabase Function Secrets. Replace with your actual keys.
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Google OAuth for local server
GOOGLE_CLIENT_ID=GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=GOOGLE_CLIENT_SECRET